<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F9F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Impôts Locaux — By SAAD"
        android:textColor="#1B7A3E"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Surface (m²)"
        android:inputType="numberDecimal"
        android:backgroundTint="#A5D6A7"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/pieces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de pièces"
        android:inputType="number"
        android:backgroundTint="#A5D6A7"
        android:layout_marginBottom="12dp"/>

    <!-- Ligne 1 : Piscine / Ascenseur / École -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <CheckBox android:id="@+id/cb_piscine"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Piscine"
            android:buttonTint="#2E7D32"/>

        <CheckBox android:id="@+id/cb_ascenseur"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Ascenseur"
            android:buttonTint="#2E7D32"/>

        <CheckBox android:id="@+id/cb_ecole"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="École"
            android:buttonTint="#2E7D32"/>
    </LinearLayout>

    <!-- Ligne 2 : Mosquée / Hôpital / Marché -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <CheckBox android:id="@+id/cb_mosquee"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Mosquée"
            android:buttonTint="#2E7D32"/>

        <CheckBox android:id="@+id/cb_hopital"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Hôpital"
            android:buttonTint="#2E7D32"/>

        <CheckBox android:id="@+id/cb_marche"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Marché"
            android:buttonTint="#2E7D32"/>
    </LinearLayout>

    <!-- Boutons Calculer / Rafraîchir -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button android:id="@+id/btn_calculer"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="Calculer"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <Button android:id="@+id/btn_reset"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="Rafraîchir"
            android:backgroundTint="#A5D6A7"
            android:textColor="#1B7A3E"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_resultat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#1B7A3E"
        android:textSize="20sp"
        android:textStyle="bold"/>

</LinearLayout>